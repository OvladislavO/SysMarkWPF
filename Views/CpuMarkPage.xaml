<Page x:Class="SysMarkWPF.Views.CpuMarkPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F5F5F5">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="70"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <!-- Шапка -->
        <Border Grid.Row="0" Background="White" CornerRadius="10"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0.5" Padding="16,12" Margin="0,0,0,12">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="CPU Mark" FontSize="20" FontWeight="Medium"
                           Foreground="#222222" HorizontalAlignment="Center"/>
                <TextBlock Text="Processor Benchmark" FontSize="12"
                           Foreground="#888888" HorizontalAlignment="Center"
                           Margin="0,2,0,0"/>
            </StackPanel>
        </Border>

        <!-- Информация о CPU -->
        <Border Grid.Row="1" Background="#F4F6F8" CornerRadius="10"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0.5" Padding="14,12" Margin="0,0,0,12">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="Processor" FontSize="11" Foreground="#888888"
                           HorizontalAlignment="Center" Margin="0,0,0,4"/>
                <TextBlock x:Name="CpuNameText" Text="—" FontSize="13"
                           FontWeight="Medium" Foreground="#333333"
                           HorizontalAlignment="Center"/>
                <TextBlock x:Name="CpuDetailsText" Text="—" FontSize="11"
                           Foreground="#888888" HorizontalAlignment="Center"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Прогресс бар -->
        <Border Grid.Row="2" Background="#F4F6F8" CornerRadius="10"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0.5" Padding="14,12" Margin="0,0,0,12">
            <StackPanel>
                <Grid Margin="0,0,0,8">
                    <TextBlock Text="Progress" FontSize="12" Foreground="#555555"/>
                    <TextBlock x:Name="ProgressText" Text="0%" FontSize="12"
                               Foreground="#555555" HorizontalAlignment="Right"/>
                </Grid>
                <ProgressBar x:Name="TestProgressBar" Height="10" Minimum="0"
                             Maximum="100" Value="0"
                             Foreground="{StaticResource GreenBrush}"
                             Background="#DDE3EA">
                    <ProgressBar.Template>
                        <ControlTemplate TargetType="ProgressBar">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="5" Height="10">
                                <Border x:Name="PART_Track">
                                    <Border x:Name="PART_Indicator"
                                            Background="{TemplateBinding Foreground}"
                                            CornerRadius="5"
                                            HorizontalAlignment="Left"/>
                                </Border>
                            </Border>
                        </ControlTemplate>
                    </ProgressBar.Template>
                </ProgressBar>
                <TextBlock x:Name="StatusText" Text="Press Start to begin the test"
                           FontSize="11" Foreground="#888888"
                           HorizontalAlignment="Center" Margin="0,6,0,0"/>
            </StackPanel>
        </Border>

        <!-- 3 карточки тестов -->
        <Grid Grid.Row="3" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Math -->
            <Border Grid.Column="0" Background="White" CornerRadius="10"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0.5" Padding="14" Margin="0,0,5,0">
                <StackPanel>
                    <TextBlock Text="Math operations" FontSize="11"
                               Foreground="#888888" HorizontalAlignment="Center"
                               Margin="0,0,0,8"/>
                    <TextBlock x:Name="MathScore" Text="—" FontSize="24"
                               FontWeight="Medium" Foreground="#333333"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="pts" FontSize="11"
                               Foreground="{StaticResource GreenBrush}"
                               HorizontalAlignment="Center" Margin="0,4,0,10"/>
                    <Border BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,0.5,0,0" Padding="0,8,0,0">
                        <StackPanel>
                            <Grid Margin="0,0,0,4">
                                <TextBlock Text="Time" FontSize="10" Foreground="#888888"/>
                                <TextBlock x:Name="MathTime" Text="— ms" FontSize="10"
                                           Foreground="#333333" HorizontalAlignment="Right"/>
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <TextBlock Text="Operations" FontSize="10" Foreground="#888888"/>
                                <TextBlock x:Name="MathOps" Text="—" FontSize="10"
                                           Foreground="#333333" HorizontalAlignment="Right"/>
                            </Grid>
                            <Grid>
                                <TextBlock Text="Speed" FontSize="10" Foreground="#888888"/>
                                <TextBlock x:Name="MathSpeed" Text="— Mop/s" FontSize="10"
                                           Foreground="#333333" HorizontalAlignment="Right"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Sorting -->
            <Border Grid.Column="1" Background="White" CornerRadius="10"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0.5" Padding="14" Margin="5,0,5,0">
                <StackPanel>
                    <TextBlock Text="Sorting" FontSize="11"
                               Foreground="#888888" HorizontalAlignment="Center"
                               Margin="0,0,0,8"/>
                    <TextBlock x:Name="SortScore" Text="—" FontSize="24"
                               FontWeight="Medium" Foreground="#333333"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="pts" FontSize="11"
                               Foreground="{StaticResource GreenBrush}"
                               HorizontalAlignment="Center" Margin="0,4,0,10"/>
                    <Border BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,0.5,0,0" Padding="0,8,0,0">
                        <StackPanel>
                            <Grid Margin="0,0,0,4">
                                <TextBlock Text="Time" FontSize="10" Foreground="#888888"/>
                                <TextBlock x:Name="SortTime" Text="— ms" FontSize="10"
                                           Foreground="#333333" HorizontalAlignment="Right"/>
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <TextBlock Text="Array size" FontSize="10" Foreground="#888888"/>
                                <TextBlock x:Name="SortSize" Text="—" FontSize="10"
                                           Foreground="#333333" HorizontalAlignment="Right"/>
                            </Grid>
                            <Grid>
                                <TextBlock Text="Algorithm" FontSize="10" Foreground="#888888"/>
                                <TextBlock Text="QuickSort" FontSize="10"
                                           Foreground="#333333" HorizontalAlignment="Right"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Encryption -->
            <Border Grid.Column="2" Background="White" CornerRadius="10"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0.5" Padding="14" Margin="5,0,0,0">
                <StackPanel>
                    <TextBlock Text="Encryption (AES)" FontSize="11"
                               Foreground="#888888" HorizontalAlignment="Center"
                               Margin="0,0,0,8"/>
                    <TextBlock x:Name="AesScore" Text="—" FontSize="24"
                               FontWeight="Medium" Foreground="#333333"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="pts" FontSize="11"
                               Foreground="{StaticResource GreenBrush}"
                               HorizontalAlignment="Center" Margin="0,4,0,10"/>
                    <Border BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,0.5,0,0" Padding="0,8,0,0">
                        <StackPanel>
                            <Grid Margin="0,0,0,4">
                                <TextBlock Text="Time" FontSize="10" Foreground="#888888"/>
                                <TextBlock x:Name="AesTime" Text="— ms" FontSize="10"
                                           Foreground="#333333" HorizontalAlignment="Right"/>
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <TextBlock Text="Data size" FontSize="10" Foreground="#888888"/>
                                <TextBlock x:Name="AesDataSize" Text="— MB" FontSize="10"
                                           Foreground="#333333" HorizontalAlignment="Right"/>
                            </Grid>
                            <Grid>
                                <TextBlock Text="Speed" FontSize="10" Foreground="#888888"/>
                                <TextBlock x:Name="AesSpeed" Text="— MB/s" FontSize="10"
                                           Foreground="#333333" HorizontalAlignment="Right"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Итоговый балл -->
        <Border Grid.Row="4" Background="{StaticResource GreenBrush}"
                CornerRadius="10" Padding="14" Margin="0,0,0,12">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="CPU Mark Score" FontSize="12"
                           Foreground="#CCFFCC" HorizontalAlignment="Center"
                           Margin="0,0,0,4"/>
                <TextBlock x:Name="TotalScore" Text="—" FontSize="36"
                           FontWeight="Medium" Foreground="White"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

       <!-- Кнопки -->
        <!-- Кнопки навигации -->
        <Grid Grid.Row="5" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="← Home"
                    Style="{StaticResource NavButtonStyle}"
                    Background="{StaticResource GreenBrush}"
                    Margin="0,0,5,0" Click="Home_Click"/>
            <Button Grid.Column="1" Content="Stop"
                    Style="{StaticResource NavButtonStyle}"
                    Background="{StaticResource YellowBrush}"
                    Margin="5,0,5,0" Click="Stop_Click"/>
            <Button Grid.Column="2" Content="Start"
                    Style="{StaticResource NavButtonStyle}"
                    Background="{StaticResource RedBrush}"
                    Margin="5,0,0,0" Click="Start_Click"/>
        </Grid>

        <!-- Кнопки сохранения -->
        <Border Grid.Row="6" Background="#F4F6F8" CornerRadius="10"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0.5" Padding="10">
            <StackPanel>
                <TextBlock Text="Save results" FontSize="10"
                           Foreground="#888888" HorizontalAlignment="Center"
                           Margin="0,0,0,8"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="Save TXT"
                            Style="{StaticResource NavButtonStyle}"
                            Background="{StaticResource GrayBrush}"
                            Height="36" FontSize="12"
                            Margin="0,0,5,0" Click="SaveTxt_Click"/>
                    <Button Grid.Column="1" Content="Save PNG"
                            Style="{StaticResource NavButtonStyle}"
                            Background="{StaticResource GrayBrush}"
                            Height="36" FontSize="12"
                            Margin="5,0,5,0" Click="SavePng_Click"/>
                    <Button Grid.Column="2" Content="Save DOCX"
                            Style="{StaticResource NavButtonStyle}"
                            Background="{StaticResource GrayBrush}"
                            Height="36" FontSize="12"
                            Margin="5,0,0,0" Click="SaveDocx_Click"/>
                </Grid>
            </StackPanel>
        </Border>
    </Grid> 
</Page>