<Page x:Class="SysMarkWPF.Views.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F5F5F5">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="70"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->
        <Border Grid.Row="0" Background="White" CornerRadius="10"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0.5" Padding="16,12" Margin="0,0,0,12">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="SysMarkWPF" FontSize="20" FontWeight="Medium"
                           Foreground="#222222" HorizontalAlignment="Center"/>
                <TextBlock Text="Performance Benchmark" FontSize="12"
                           Foreground="#888888" HorizontalAlignment="Center"
                           Margin="0,2,0,0"/>
            </StackPanel>
        </Border>

        <!-- System Information -->
        <Border Grid.Row="1" Background="#F4F6F8" CornerRadius="10"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0.5" Padding="16" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="SYSTEM INFORMATION" FontSize="11"
                           FontWeight="Medium" Foreground="#555555"
                           HorizontalAlignment="Center" Margin="0,0,0,10"/>

                <!-- Верхний ряд карточек -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- CPU -->
                    <Border Grid.Column="0" Style="{StaticResource InfoCardStyle}"
                            Margin="0,0,5,0" MinHeight="90">
                        <StackPanel>
                            <TextBlock Text="CPU" Style="{StaticResource CardLabelStyle}"/>
                            <TextBlock x:Name="CpuName" Text="—"
                                       Style="{StaticResource CardValueStyle}"
                                       TextWrapping="Wrap"/>
                            <TextBlock x:Name="CpuCores" Text="—"
                                       Style="{StaticResource CardSubValueStyle}"
                                       TextWrapping="Wrap"/>
                            <TextBlock x:Name="CpuSpeed" Text="—"
                                       Style="{StaticResource CardSubValueStyle}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- RAM -->
                    <Border Grid.Column="1" Style="{StaticResource InfoCardStyle}"
                            Margin="5,0,5,0" MinHeight="90">
                        <StackPanel>
                            <TextBlock Text="RAM" Style="{StaticResource CardLabelStyle}"/>
                            <TextBlock x:Name="RamTotal" Text="—"
                                       Style="{StaticResource CardValueStyle}"
                                       TextWrapping="Wrap"/>
                            <TextBlock x:Name="RamSpeed" Text="—"
                                       Style="{StaticResource CardSubValueStyle}"
                                       TextWrapping="Wrap"/>
                            <TextBlock x:Name="RamAvailable" Text="—"
                                       Style="{StaticResource CardSubValueStyle}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- GPU -->
                    <Border Grid.Column="2" Style="{StaticResource InfoCardStyle}"
                            Margin="5,0,5,0" MinHeight="90">
                        <StackPanel>
                            <TextBlock Text="GPU" Style="{StaticResource CardLabelStyle}"/>
                            <TextBlock x:Name="GpuName" Text="—"
                                       Style="{StaticResource CardValueStyle}"
                                       TextWrapping="Wrap"/>
                            <TextBlock x:Name="GpuVram" Text="—"
                                       Style="{StaticResource CardSubValueStyle}"
                                       TextWrapping="Wrap"/>
                            <TextBlock x:Name="GpuDriver" Text="—"
                                       Style="{StaticResource CardSubValueStyle}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- Disk -->
                    <Border Grid.Column="3" Style="{StaticResource InfoCardStyle}"
                            Margin="5,0,0,0" MinHeight="90">
                        <StackPanel>
                            <TextBlock Text="Disk" Style="{StaticResource CardLabelStyle}"/>
                            <TextBlock x:Name="DiskName" Text="—"
                                       Style="{StaticResource CardValueStyle}"
                                       TextWrapping="Wrap"/>
                            <TextBlock x:Name="DiskType" Text="—"
                                       Style="{StaticResource CardSubValueStyle}"
                                       TextWrapping="Wrap"/>
                            <TextBlock x:Name="DiskFree" Text="—"
                                       Style="{StaticResource CardSubValueStyle}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Нижний ряд карточек -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- OS -->
                    <Border Grid.Column="0" Style="{StaticResource InfoCardStyle}"
                            Margin="0,0,5,0" MinHeight="70">
                        <StackPanel>
                            <TextBlock Text="Operating system"
                                       Style="{StaticResource CardLabelStyle}"/>
                            <TextBlock x:Name="OsName" Text="—"
                                       Style="{StaticResource CardValueStyle}"
                                       TextWrapping="Wrap"/>
                            <TextBlock x:Name="OsBuild" Text="—"
                                       Style="{StaticResource CardSubValueStyle}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- Computer -->
                    <Border Grid.Column="1" Style="{StaticResource InfoCardStyle}"
                            Margin="5,0,5,0" MinHeight="70">
                        <StackPanel>
                            <TextBlock Text="Computer name"
                                       Style="{StaticResource CardLabelStyle}"/>
                            <TextBlock x:Name="ComputerName" Text="—"
                                       Style="{StaticResource CardValueStyle}"
                                       TextWrapping="Wrap"/>
                            <TextBlock x:Name="UserName" Text="—"
                                       Style="{StaticResource CardSubValueStyle}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- Network -->
                    <Border Grid.Column="2" Style="{StaticResource InfoCardStyle}"
                            Margin="5,0,0,0" MinHeight="70">
                        <StackPanel>
                            <TextBlock Text="Network"
                                       Style="{StaticResource CardLabelStyle}"/>
                            <TextBlock x:Name="NetworkAdapter" Text="—"
                                       Style="{StaticResource CardValueStyle}"
                                       TextWrapping="Wrap"/>
                            <TextBlock x:Name="NetworkIp" Text="—"
                                       Style="{StaticResource CardSubValueStyle}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Пустое пространство -->
        <Grid Grid.Row="2"/>

        <!-- Кнопки навигации -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="CPU Mark"
                    Style="{StaticResource NavButtonStyle}"
                    Background="{StaticResource GreenBrush}"
                    Margin="0,0,5,0" Click="CpuMark_Click"/>
            <Button Grid.Column="1" Content="Memory Mark"
                    Style="{StaticResource NavButtonStyle}"
                    Background="{StaticResource YellowBrush}"
                    Margin="5,0,5,0" Click="MemoryMark_Click"/>
            <Button Grid.Column="2" Content="Disk Mark"
                    Style="{StaticResource NavButtonStyle}"
                    Background="{StaticResource RedBrush}"
                    Margin="5,0,5,0" Click="DiskMark_Click"/>
            <Button Grid.Column="3" Content="PassMark"
                    Style="{StaticResource NavButtonStyle}"
                    Background="{StaticResource BlueBrush}"
                    Margin="5,0,0,0" Click="PassMark_Click"/>
        </Grid>
    </Grid>
</Page>