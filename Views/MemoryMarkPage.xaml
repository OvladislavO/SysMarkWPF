<Page x:Class="SysMarkWPF.Views.MemoryMarkPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F5F5F5">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="70"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->
        <Border Grid.Row="0" Background="White" CornerRadius="10"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0.5" Padding="16,12" Margin="0,0,0,12">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="Memory Mark" FontSize="20" FontWeight="Medium"
                           Foreground="#222222" HorizontalAlignment="Center"/>
                <TextBlock Text="RAM Benchmark" FontSize="12"
                           Foreground="#888888" HorizontalAlignment="Center"
                           Margin="0,2,0,0"/>
            </StackPanel>
        </Border>

        <!-- Информация о RAM -->
        <Border Grid.Row="1" Background="#F4F6F8" CornerRadius="10"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0.5" Padding="14,12" Margin="0,0,0,12">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="Memory" FontSize="11" Foreground="#888888"
                           HorizontalAlignment="Center" Margin="0,0,0,4"/>
                <TextBlock x:Name="RamNameText" Text="—" FontSize="13"
                           FontWeight="Medium" Foreground="#333333"
                           HorizontalAlignment="Center"/>
                <TextBlock x:Name="RamDetailsText" Text="—" FontSize="11"
                           Foreground="#888888" HorizontalAlignment="Center"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Прогресс бар -->
        <Border Grid.Row="2" Background="#F4F6F8" CornerRadius="10"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0.5" Padding="14,12" Margin="0,0,0,12">
            <StackPanel>
                <Grid Margin="0,0,0,8">
                    <TextBlock Text="Progress" FontSize="12" Foreground="#555555"/>
                    <TextBlock x:Name="ProgressText" Text="0%" FontSize="12"
                               Foreground="#555555" HorizontalAlignment="Right"/>
                </Grid>
                <ProgressBar x:Name="TestProgressBar" Height="10" Minimum="0"
                             Maximum="100" Value="0"
                             Foreground="{StaticResource YellowBrush}"
                             Background="#DDE3EA">
                    <ProgressBar.Template>
                        <ControlTemplate TargetType="ProgressBar">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="5" Height="10">
                                <Border x:Name="PART_Track">
                                    <Border x:Name="PART_Indicator"
                                            Background="{TemplateBinding Foreground}"
                                            CornerRadius="5"
                                            HorizontalAlignment="Left"/>
                                </Border>
                            </Border>
                        </ControlTemplate>
                    </ProgressBar.Template>
                </ProgressBar>
                <TextBlock x:Name="StatusText" Text="Press Start to begin the test"
                           FontSize="11" Foreground="#888888"
                           HorizontalAlignment="Center" Margin="0,6,0,0"/>
            </StackPanel>
        </Border>

        <!-- 3 карточки тестов -->
        <Grid Grid.Row="3" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sequential Read -->
            <Border Grid.Column="0" Background="White" CornerRadius="10"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0.5" Padding="14" Margin="0,0,5,0">
                <StackPanel>
                    <TextBlock Text="Sequential Read" FontSize="11"
                               Foreground="#888888" HorizontalAlignment="Center"
                               Margin="0,0,0,8"/>
                    <TextBlock x:Name="ReadScore" Text="—" FontSize="24"
                               FontWeight="Medium" Foreground="#333333"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="pts" FontSize="11"
                               Foreground="{StaticResource YellowBrush}"
                               HorizontalAlignment="Center" Margin="0,4,0,10"/>
                    <Border BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,0.5,0,0" Padding="0,8,0,0">
                        <StackPanel>
                            <Grid Margin="0,0,0,4">
                                <TextBlock Text="Speed" FontSize="10" Foreground="#888888"/>
                                <TextBlock x:Name="ReadSpeed" Text="— MB/s" FontSize="10"
                                           Foreground="#333333" HorizontalAlignment="Right"/>
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <TextBlock Text="Block size" FontSize="10" Foreground="#888888"/>
                                <TextBlock x:Name="ReadBlock" Text="— MB" FontSize="10"
                                           Foreground="#333333" HorizontalAlignment="Right"/>
                            </Grid>
                            <Grid>
                                <TextBlock Text="Time" FontSize="10" Foreground="#888888"/>
                                <TextBlock x:Name="ReadTime" Text="— ms" FontSize="10"
                                           Foreground="#333333" HorizontalAlignment="Right"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Sequential Write -->
            <Border Grid.Column="1" Background="White" CornerRadius="10"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0.5" Padding="14" Margin="5,0,5,0">
                <StackPanel>
                    <TextBlock Text="Sequential Write" FontSize="11"
                               Foreground="#888888" HorizontalAlignment="Center"
                               Margin="0,0,0,8"/>
                    <TextBlock x:Name="WriteScore" Text="—" FontSize="24"
                               FontWeight="Medium" Foreground="#333333"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="pts" FontSize="11"
                               Foreground="{StaticResource YellowBrush}"
                               HorizontalAlignment="Center" Margin="0,4,0,10"/>
                    <Border BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,0.5,0,0" Padding="0,8,0,0">
                        <StackPanel>
                            <Grid Margin="0,0,0,4">
                                <TextBlock Text="Speed" FontSize="10" Foreground="#888888"/>
                                <TextBlock x:Name="WriteSpeed" Text="— MB/s" FontSize="10"
                                           Foreground="#333333" HorizontalAlignment="Right"/>
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <TextBlock Text="Block size" FontSize="10" Foreground="#888888"/>
                                <TextBlock x:Name="WriteBlock" Text="— MB" FontSize="10"
                                           Foreground="#333333" HorizontalAlignment="Right"/>
                            </Grid>
                            <Grid>
                                <TextBlock Text="Time" FontSize="10" Foreground="#888888"/>
                                <TextBlock x:Name="WriteTime" Text="— ms" FontSize="10"
                                           Foreground="#333333" HorizontalAlignment="Right"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Latency -->
            <Border Grid.Column="2" Background="White" CornerRadius="10"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0.5" Padding="14" Margin="5,0,0,0">
                <StackPanel>
                    <TextBlock Text="Latency" FontSize="11"
                               Foreground="#888888" HorizontalAlignment="Center"
                               Margin="0,0,0,8"/>
                    <TextBlock x:Name="LatencyScore" Text="—" FontSize="24"
                               FontWeight="Medium" Foreground="#333333"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="pts" FontSize="11"
                               Foreground="{StaticResource YellowBrush}"
                               HorizontalAlignment="Center" Margin="0,4,0,10"/>
                    <Border BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,0.5,0,0" Padding="0,8,0,0">
                        <StackPanel>
                            <Grid Margin="0,0,0,4">
                                <TextBlock Text="Latency" FontSize="10" Foreground="#888888"/>
                                <TextBlock x:Name="LatencyNs" Text="— ns" FontSize="10"
                                           Foreground="#333333" HorizontalAlignment="Right"/>
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <TextBlock Text="Accesses" FontSize="10" Foreground="#888888"/>
                                <TextBlock x:Name="LatencyAccesses" Text="—" FontSize="10"
                                           Foreground="#333333" HorizontalAlignment="Right"/>
                            </Grid>
                            <Grid>
                                <TextBlock Text="Time" FontSize="10" Foreground="#888888"/>
                                <TextBlock x:Name="LatencyTime" Text="— ms" FontSize="10"
                                           Foreground="#333333" HorizontalAlignment="Right"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Итоговый балл -->
        <Border Grid.Row="4" Background="{StaticResource YellowBrush}"
                CornerRadius="10" Padding="14" Margin="0,0,0,12">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="Memory Mark Score" FontSize="12"
                           Foreground="White" HorizontalAlignment="Center"
                           Margin="0,0,0,4"/>
                <TextBlock x:Name="TotalScore" Text="—" FontSize="36"
                           FontWeight="Medium" Foreground="White"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Кнопки -->
        <Grid Grid.Row="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="← Home"
                    Style="{StaticResource NavButtonStyle}"
                    Background="{StaticResource GreenBrush}"
                    Margin="0,0,5,0" Click="Home_Click"/>
            <Button Grid.Column="1" Content="Stop"
                    Style="{StaticResource NavButtonStyle}"
                    Background="{StaticResource YellowBrush}"
                    Margin="5,0,5,0" Click="Stop_Click"/>
            <Button Grid.Column="2" Content="Start"
                    Style="{StaticResource NavButtonStyle}"
                    Background="{StaticResource RedBrush}"
                    Margin="5,0,0,0" Click="Start_Click"/>
        </Grid>
    </Grid>
</Page>