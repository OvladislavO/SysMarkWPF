<Page x:Class="SysMarkWPF.Views.NetworkMarkPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F5F5F5">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="70"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->
        <Border Grid.Row="0" Background="White" CornerRadius="10"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0.5" Padding="16,12" Margin="0,0,0,12">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="Network Mark" FontSize="20" FontWeight="Medium"
                           Foreground="#222222" HorizontalAlignment="Center"/>
                <TextBlock Text="Network Benchmark" FontSize="12"
                           Foreground="#888888" HorizontalAlignment="Center"
                           Margin="0,2,0,0"/>
            </StackPanel>
        </Border>

        <!-- Информация об адаптере -->
        <Border Grid.Row="1" Background="#F4F6F8" CornerRadius="10"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0.5" Padding="14,12" Margin="0,0,0,12">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="Network Adapter" FontSize="11"
                           Foreground="#888888" HorizontalAlignment="Center"
                           Margin="0,0,0,4"/>
                <TextBlock x:Name="AdapterNameText" Text="—" FontSize="13"
                           FontWeight="Medium" Foreground="#333333"
                           HorizontalAlignment="Center"/>
                <TextBlock x:Name="AdapterDetailsText" Text="—" FontSize="11"
                           Foreground="#888888" HorizontalAlignment="Center"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Прогресс бар -->
        <Border Grid.Row="2" Background="#F4F6F8" CornerRadius="10"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0.5" Padding="14,12" Margin="0,0,0,12">
            <StackPanel>
                <Grid Margin="0,0,0,8">
                    <TextBlock Text="Progress" FontSize="12" Foreground="#555555"/>
                    <TextBlock x:Name="ProgressText" Text="0%" FontSize="12"
                               Foreground="#555555" HorizontalAlignment="Right"/>
                </Grid>
                <ProgressBar x:Name="TestProgressBar" Height="10"
                             Minimum="0" Maximum="100" Value="0"
                             Foreground="{StaticResource PurpleBrush}"
                             Background="#DDE3EA">
                    <ProgressBar.Template>
                        <ControlTemplate TargetType="ProgressBar">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="5" Height="10">
                                <Border x:Name="PART_Track">
                                    <Border x:Name="PART_Indicator"
                                            Background="{TemplateBinding Foreground}"
                                            CornerRadius="5"
                                            HorizontalAlignment="Left"/>
                                </Border>
                            </Border>
                        </ControlTemplate>
                    </ProgressBar.Template>
                </ProgressBar>
                <TextBlock x:Name="StatusText" Text="Press Start to begin the test"
                           FontSize="11" Foreground="#888888"
                           HorizontalAlignment="Center" Margin="0,6,0,0"/>
            </StackPanel>
        </Border>

        <!-- 3 карточки тестов -->
        <Grid Grid.Row="3" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Ping -->
            <Border Grid.Column="0" Background="White" CornerRadius="10"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0.5" Padding="14" Margin="0,0,5,0">
                <StackPanel>
                    <TextBlock Text="Ping" FontSize="11" Foreground="#888888"
                               HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock x:Name="PingScore" Text="—" FontSize="24"
                               FontWeight="Medium" Foreground="#333333"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="pts" FontSize="11"
                               Foreground="{StaticResource PurpleBrush}"
                               HorizontalAlignment="Center" Margin="0,4,0,10"/>
                    <Border BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,0.5,0,0" Padding="0,8,0,0">
                        <StackPanel>
                            <Grid Margin="0,0,0,4">
                                <TextBlock Text="Avg ping" FontSize="10" Foreground="#888888"/>
                                <TextBlock x:Name="PingAvg" Text="— ms" FontSize="10"
                                           Foreground="#333333" HorizontalAlignment="Right"/>
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <TextBlock Text="Min ping" FontSize="10" Foreground="#888888"/>
                                <TextBlock x:Name="PingMin" Text="— ms" FontSize="10"
                                           Foreground="#333333" HorizontalAlignment="Right"/>
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <TextBlock Text="Max ping" FontSize="10" Foreground="#888888"/>
                                <TextBlock x:Name="PingMax" Text="— ms" FontSize="10"
                                           Foreground="#333333" HorizontalAlignment="Right"/>
                            </Grid>
                            <Grid>
                                <TextBlock Text="Packet loss" FontSize="10" Foreground="#888888"/>
                                <TextBlock x:Name="PingLoss" Text="— %" FontSize="10"
                                           Foreground="#333333" HorizontalAlignment="Right"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- DNS Speed -->
            <Border Grid.Column="1" Background="White" CornerRadius="10"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0.5" Padding="14" Margin="5,0,5,0">
                <StackPanel>
                    <TextBlock Text="DNS Speed" FontSize="11" Foreground="#888888"
                               HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock x:Name="DnsScore" Text="—" FontSize="24"
                               FontWeight="Medium" Foreground="#333333"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="pts" FontSize="11"
                               Foreground="{StaticResource PurpleBrush}"
                               HorizontalAlignment="Center" Margin="0,4,0,10"/>
                    <Border BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,0.5,0,0" Padding="0,8,0,0">
                        <StackPanel>
                            <Grid Margin="0,0,0,4">
                                <TextBlock Text="Avg DNS" FontSize="10" Foreground="#888888"/>
                                <TextBlock x:Name="DnsAvg" Text="— ms" FontSize="10"
                                           Foreground="#333333" HorizontalAlignment="Right"/>
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <TextBlock Text="Google DNS" FontSize="10" Foreground="#888888"/>
                                <TextBlock x:Name="DnsGoogle" Text="— ms" FontSize="10"
                                           Foreground="#333333" HorizontalAlignment="Right"/>
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <TextBlock Text="Cloudflare" FontSize="10" Foreground="#888888"/>
                                <TextBlock x:Name="DnsCloudflare" Text="— ms" FontSize="10"
                                           Foreground="#333333" HorizontalAlignment="Right"/>
                            </Grid>
                            <Grid>
                                <TextBlock Text="Queries" FontSize="10" Foreground="#888888"/>
                                <TextBlock x:Name="DnsQueries" Text="—" FontSize="10"
                                           Foreground="#333333" HorizontalAlignment="Right"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Adapter Info -->
            <Border Grid.Column="2" Background="White" CornerRadius="10"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0.5" Padding="14" Margin="5,0,0,0">
                <StackPanel>
                    <TextBlock Text="Adapter" FontSize="11" Foreground="#888888"
                               HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock x:Name="AdapterScore" Text="—" FontSize="24"
                               FontWeight="Medium" Foreground="#333333"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="pts" FontSize="11"
                               Foreground="{StaticResource PurpleBrush}"
                               HorizontalAlignment="Center" Margin="0,4,0,10"/>
                    <Border BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,0.5,0,0" Padding="0,8,0,0">
                        <StackPanel>
                            <Grid Margin="0,0,0,4">
                                <TextBlock Text="Link speed" FontSize="10" Foreground="#888888"/>
                                <TextBlock x:Name="AdapterSpeed" Text="— Mbps" FontSize="10"
                                           Foreground="#333333" HorizontalAlignment="Right"/>
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <TextBlock Text="Type" FontSize="10" Foreground="#888888"/>
                                <TextBlock x:Name="AdapterType" Text="—" FontSize="10"
                                           Foreground="#333333" HorizontalAlignment="Right"/>
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <TextBlock Text="IP Address" FontSize="10" Foreground="#888888"/>
                                <TextBlock x:Name="AdapterIp" Text="—" FontSize="10"
                                           Foreground="#333333" HorizontalAlignment="Right"/>
                            </Grid>
                            <Grid>
                                <TextBlock Text="MAC" FontSize="10" Foreground="#888888"/>
                                <TextBlock x:Name="AdapterMac" Text="—" FontSize="10"
                                           Foreground="#333333" HorizontalAlignment="Right"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Итоговый балл -->
        <Border Grid.Row="4" Background="{StaticResource PurpleBrush}"
                CornerRadius="10" Padding="14" Margin="0,0,0,12">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="Network Mark Score" FontSize="12"
                           Foreground="White" HorizontalAlignment="Center"
                           Margin="0,0,0,4"/>
                <TextBlock x:Name="TotalScore" Text="—" FontSize="36"
                           FontWeight="Medium" Foreground="White"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Кнопки -->
        <!-- Кнопки навигации -->
        <Grid Grid.Row="5" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="← Home"
                    Style="{StaticResource NavButtonStyle}"
                    Background="{StaticResource GreenBrush}"
                    Margin="0,0,5,0" Click="Home_Click"/>
            <Button Grid.Column="1" Content="Stop"
                    Style="{StaticResource NavButtonStyle}"
                    Background="{StaticResource YellowBrush}"
                    Margin="5,0,5,0" Click="Stop_Click"/>
            <Button Grid.Column="2" Content="Start"
                    Style="{StaticResource NavButtonStyle}"
                    Background="{StaticResource RedBrush}"
                    Margin="5,0,0,0" Click="Start_Click"/>
        </Grid>

        <!-- Кнопки сохранения -->
        <Border Grid.Row="6" Background="#F4F6F8" CornerRadius="10"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0.5" Padding="10">
            <StackPanel>
                <TextBlock Text="Save results" FontSize="10"
                           Foreground="#888888" HorizontalAlignment="Center"
                           Margin="0,0,0,8"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="Save TXT"
                            Style="{StaticResource NavButtonStyle}"
                            Background="{StaticResource GrayBrush}"
                            Height="36" FontSize="12"
                            Margin="0,0,5,0" Click="SaveTxt_Click"/>
                    <Button Grid.Column="1" Content="Save PNG"
                            Style="{StaticResource NavButtonStyle}"
                            Background="{StaticResource GrayBrush}"
                            Height="36" FontSize="12"
                            Margin="5,0,5,0" Click="SavePng_Click"/>
                    <Button Grid.Column="2" Content="Save DOCX"
                            Style="{StaticResource NavButtonStyle}"
                            Background="{StaticResource GrayBrush}"
                            Height="36" FontSize="12"
                            Margin="5,0,0,0" Click="SaveDocx_Click"/>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</Page> 